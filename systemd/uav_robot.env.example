UAV_ROBOTD_ARGS="--listen-port 9001"
UAV_PROC_REALSENSE_ARGS=""
UAV_REALSENSE_WIDTH="424"
UAV_REALSENSE_HEIGHT="240"
UAV_REALSENSE_FPS="15"
UAV_REALSENSE_DISABLE_DEPTH="0"
UAV_PROC_NPU_ARGS=""
UAV_PROC_GATEWAY_ARGS=""
UAV_PROC_CAR_ARGS=""
UAV_PROC_GRIPPER_ARGS=""
UAV_PROC_ARM_ARGS=""
UAV_PROC_AIRPORT_ARGS=""
UAV_LOG_FILE="/tmp/uav_robotd.log"
UAV_TASK_STATUS_FILE="/tmp/uav_task_status.json"
UAV_VIDEO_STREAM_ENABLED="1"

# Arm CAN / kinematics tuning
UAV_ARM_CAN_IFACE="can4"
UAV_ARM_RPM="300"
UAV_ARM_ACC="20"
UAV_ARM_ACK_TIMEOUT_MS="200"
UAV_ARM_WAIT_REACHED="0"
UAV_ARM_REACHED_TIMEOUT_MS="8000"
UAV_ARM_HOME_SETTLE_MS="2500"
UAV_ARM_J1_RATIO="25"
UAV_ARM_J2_RATIO="20"
UAV_ARM_J3_RATIO="25"
UAV_ARM_J4_RATIO="10"
UAV_ARM_J5_RATIO="4"
UAV_ARM_J6_RATIO="1"
UAV_ARM_J1_MIN_DEG="-180"
UAV_ARM_J1_MAX_DEG="160"
UAV_ARM_J2_MIN_DEG="0"
UAV_ARM_J2_MAX_DEG="180"
UAV_ARM_J3_MIN_DEG="-80"
UAV_ARM_J3_MAX_DEG="83"
UAV_ARM_J4_MIN_DEG="-30"
UAV_ARM_J4_MAX_DEG="305"
UAV_ARM_J5_MIN_DEG="-110"
UAV_ARM_J5_MAX_DEG="110"
UAV_ARM_J6_MIN_DEG="-30"
UAV_ARM_J6_MAX_DEG="305"

# CAN chassis tuning for proc_gateway
UAV_CAR_CAN_IFACE="can3"
UAV_CAR_TRACK_WIDTH_MM="600"
UAV_CAR_MM_PER_SEC_PER_RPM="5.0"
UAV_CAR_MIN_RPM="60"
UAV_CAR_TURN_MIN_RPM="90"
UAV_CAR_LIMIT_PWM="800"
UAV_CAR_TURN_LIMIT_PWM="1200"
UAV_CAR_RAMP_STEPS="4"
UAV_CAR_RAMP_DT_MS="50"
UAV_CAR_MIN_SEND_INTERVAL_MS="120"
UAV_CAR_LEFT_TRIM="1.0"
UAV_CAR_RIGHT_TRIM="1.0"

# Airport rails (ZDT / Emm V5.0 on CAN)
UAV_AIRPORT_CAN_IFACE="can1"
UAV_AIRPORT_RAIL1_ADDR="1"
UAV_AIRPORT_RAIL2_ADDR="2"
UAV_AIRPORT_RAIL3_ADDR="3"
UAV_AIRPORT_RAIL_RPM="1500"
UAV_AIRPORT_RAIL_ACC="0"
UAV_AIRPORT_RAIL_PULSES_PER_MM="100"

# Airport relay outputs: firmware may expose GPIO_1~GPIO_3 and IO4/EXTIO4.
# proc_gateway accepts GPIO_1, GPIO1, IO4, IO_4, EXTIO4, or EXT_IO4 and
# resolves to the existing sysfs node at runtime.
UAV_AIRPORT_RELAY1_PATH="GPIO_1"
UAV_AIRPORT_RELAY1_ACTIVE_HIGH="1"
UAV_AIRPORT_RELAY2_PATH="GPIO_2"
UAV_AIRPORT_RELAY2_ACTIVE_HIGH="1"
UAV_AIRPORT_RELAY3_PATH="GPIO_3"
UAV_AIRPORT_RELAY3_ACTIVE_HIGH="1"
UAV_AIRPORT_RELAY4_PATH="IO4"
UAV_AIRPORT_RELAY4_ACTIVE_HIGH="1"
UAV_AIRPORT_GRIPPER_RELAY_PATH="IO4"
UAV_AIRPORT_GRIPPER_ACTIVE_HIGH="1"

# Arm gripper UART (115200 8N1)
UAV_GRIPPER_UART_PATH="/dev/ttyUSB0"
